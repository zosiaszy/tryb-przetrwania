{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/cover.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
      ]
    },
    {
      "source": "/cover-email.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
